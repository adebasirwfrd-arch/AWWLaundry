# AWW Laundry — Environment Template
# Salin: cp .env.example .env.local
# Isi secret dari docs/ENV-SECRETS.md Section 0 (Project Instance)
# JANGAN commit .env.local ke git

# ── App ──────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AWW Laundry"

# ── GitHub & Expo ────────────────────────────────
GITHUB_REPO=https://github.com/adebasirwfrd-arch/AWWLaundry.git
EAS_PROJECT_ID=56aa0cad-497c-4e5f-af20-1d866f93e8b7
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ── Supabase ─────────────────────────────────────
SUPABASE_PROJECT_ID=svsakpnvikwrdoxxnfys
NEXT_PUBLIC_SUPABASE_URL=https://svsakpnvikwrdoxxnfys.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_STORAGE_BUCKET=aww-laundry

# Prisma — ambil DB password dari Supabase Dashboard > Settings > Database
DATABASE_URL="postgresql://postgres.svsakpnvikwrdoxxnfys:YOUR_DB_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.svsakpnvikwrdoxxnfys:YOUR_DB_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── Auth.js v5 ───────────────────────────────────
# Generate: npx auth secret
AUTH_SECRET=your_auth_secret_here
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Google OAuth ─────────────────────────────────
# Project: csms-application-478203
# Redirect URI WAJIB: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=1056146520050-scqqdt75ablueftnaf5453ctctl6r7m2.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret

# Mobile Google (sama web client untuk dev)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=1056146520050-scqqdt75ablueftnaf5453ctctl6r7m2.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id

# ── Brevo Email ────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=adeazhar.wfrd@gmail.com
BREVO_SENDER_NAME="AWW Laundry"

# ── Phase 2: Redis (Upstash) — DUMMY ───────────
REDIS_URL=rediss://default:DUMMY_UPSTASH_TOKEN@DUMMY.upstash.io:6379

# ── Phase 2: Midtrans Sandbox — DUMMY ───────────
MIDTRANS_SERVER_KEY=SB-Mid-server-DUMMY_REPLACE_ME
MIDTRANS_CLIENT_KEY=SB-Mid-client-DUMMY_REPLACE_ME
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-DUMMY_REPLACE_ME

# ── Phase 2: Cloudflare R2 — DUMMY ─────────────
S3_ENDPOINT=https://DUMMY_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=DUMMY_ACCESS_KEY
S3_SECRET_ACCESS_KEY=DUMMY_SECRET_KEY
S3_BUCKET_NAME=aww-laundry
S3_REGION=auto
S3_PUBLIC_URL=https://cdn.awwlaundry.com

# ── Phase 2: Real-time — DUMMY ─────────────────
SOCKET_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ── Phase 3: OpenAI ──────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_CHATBOT=gpt-4o-mini
OPENAI_MODEL_BUSINESS=gpt-4o-mini

# ── Phase 4: Push & WhatsApp — DUMMY ───────────
FCM_SERVER_KEY=DUMMY_FCM_SERVER_KEY
FONNTE_API_KEY=DUMMY_FONNTE_API_KEY
WABLAS_API_KEY=DUMMY_WABLAS_API_KEY

# ── Monitoring — DUMMY ─────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
CRON_SECRET=DUMMY_CRON_SECRET_GENERATE_WITH_openssl_rand_hex_32
